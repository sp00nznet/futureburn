<Window x:Class="Futureburn.Gui.BurnImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Burn Blu-ray / DVD"
        Height="420" Width="700"
        MinHeight="320" MinWidth="500"
        WindowStartupLocation="CenterOwner">
  <DockPanel>

    <ToolBar DockPanel.Dock="Top">
      <Button Content="Choose ISO..."    Click="ChooseIso_Click"    Padding="10,4"/>
      <Button Content="Choose folder..." Click="ChooseFolder_Click" Padding="10,4"/>
      <Button Content="Choose video..."  Click="ChooseVideo_Click"  Padding="10,4"/>
      <CheckBox x:Name="MenuCheck" Content="DVD menu" VerticalAlignment="Center" Margin="8,0,2,0"
                ToolTip="With Choose video: author a Play / Scene Selection menu instead of auto-play."/>
      <Separator/>
      <TextBlock Text="Drive:" VerticalAlignment="Center" Margin="6,0,4,0"/>
      <ComboBox x:Name="DriveCombo" Width="240"/>
      <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="12,0,4,0"/>
      <ComboBox x:Name="SpeedCombo" Width="80" SelectedIndex="0">
        <ComboBoxItem Content="default"/>
        <ComboBoxItem Content="2x"/>
        <ComboBoxItem Content="4x"/>
        <ComboBoxItem Content="8x"/>
        <ComboBoxItem Content="16x"/>
      </ComboBox>
    </ToolBar>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusText" Text="Pick an ISO image to burn."/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <ProgressBar x:Name="Progress" Width="240" Height="14" Minimum="0" Maximum="100"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap">
        <Run Text="Burn a pre-built ISO, a folder of files (we build the ISO 9660+Joliet+UDF), or "/>
        <Run FontWeight="SemiBold" Text="Choose video"/>
        <Run Text=" — transcode an MKV / MP4 into a real DVD-Video, carrying its chapters, audio tracks and subtitles, ready to burn and play in a DVD player."/>
      </TextBlock>

      <Border Grid.Row="1"
              BorderBrush="#888"
              BorderThickness="1"
              CornerRadius="4"
              Padding="14"
              Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Selected image:" FontWeight="SemiBold"/>
          <TextBlock x:Name="IsoPathText" Margin="0,4,0,0" Text="(none)" Opacity="0.8"/>
          <TextBlock x:Name="IsoSizeText" Margin="0,2,0,0" Opacity="0.6"/>
        </StackPanel>
      </Border>

      <TextBlock Grid.Row="2" x:Name="DiscFitText"
                 FontSize="12"
                 Opacity="0.7"
                 TextWrapping="Wrap"/>

      <Grid Grid.Row="3" Margin="0,10,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="DriveDiscText" VerticalAlignment="Center"/>
        <Button x:Name="BurnBtn"
                Grid.Column="1"
                Content="Burn"
                Click="Burn_Click"
                Padding="30,6"
                FontSize="14"
                IsEnabled="False"/>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
