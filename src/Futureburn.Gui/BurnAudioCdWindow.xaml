<Window x:Class="Futureburn.Gui.BurnAudioCdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Burn Audio CD"
        Height="560" Width="780"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
  <DockPanel>

    <ToolBar DockPanel.Dock="Top">
      <Button Content="Add files..."     Click="AddFiles_Click"    Padding="10,4"/>
      <Button Content="Add folder..."    Click="AddFolder_Click"   Padding="10,4"/>
      <Button Content="Load M3U..."      Click="LoadPlaylist_Click" Padding="10,4"/>
      <Separator/>
      <Button x:Name="MoveUpBtn"   Content="Move up"   Click="MoveUp_Click"   Padding="10,4"/>
      <Button x:Name="MoveDownBtn" Content="Move down" Click="MoveDown_Click" Padding="10,4"/>
      <Button x:Name="RenameBtn"   Content="Rename"    Click="Rename_Click"   Padding="10,4"/>
      <Button x:Name="RemoveBtn"   Content="Remove"    Click="Remove_Click"   Padding="10,4"/>
      <Separator/>
      <Button x:Name="PlayBtn" Content="▶ Play" Click="Play_Click" Padding="10,4"/>
      <Button x:Name="StopBtn" Content="■ Stop" Click="Stop_Click" Padding="10,4" IsEnabled="False"/>
      <Separator/>
      <Button Content="Save M3U8..."   Click="SaveM3U_Click"   Padding="10,4"/>
      <Separator/>
      <TextBlock Text="Drive:" VerticalAlignment="Center" Margin="6,0,4,0"/>
      <ComboBox x:Name="DriveCombo" Width="240"/>
      <TextBlock Text="Engine:" VerticalAlignment="Center" Margin="12,0,4,0"/>
      <ComboBox x:Name="EngineCombo" Width="80" SelectedIndex="0">
        <ComboBoxItem Content="spti"/>
        <ComboBoxItem Content="v2"/>
        <ComboBoxItem Content="v1"/>
      </ComboBox>
      <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="12,0,4,0"/>
      <ComboBox x:Name="SpeedCombo" Width="70" SelectedIndex="2">
        <ComboBoxItem Content="default"/>
        <ComboBoxItem Content="4x"/>
        <ComboBoxItem Content="8x"/>
        <ComboBoxItem Content="16x"/>
        <ComboBoxItem Content="24x"/>
        <ComboBoxItem Content="48x"/>
      </ComboBox>
    </ToolBar>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusText" Text="Ready."/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <ProgressBar x:Name="Progress" Width="240" Height="14" Minimum="0" Maximum="100"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <ListView Grid.Row="0" x:Name="TrackList"
                AllowDrop="True"
                PreviewMouseLeftButtonDown="TrackList_PreviewMouseLeftButtonDown"
                PreviewMouseMove="TrackList_PreviewMouseMove"
                DragOver="TrackList_DragOver"
                Drop="TrackList_DropOnList"
                MouseDoubleClick="TrackList_MouseDoubleClick"
                KeyDown="TrackList_KeyDown">
        <ListView.View>
          <GridView>
            <GridView.Columns>
              <GridViewColumn Header="#"        Width="40"  DisplayMemberBinding="{Binding Index}"/>
              <GridViewColumn Header="Title"    Width="430" DisplayMemberBinding="{Binding Title}"/>
              <GridViewColumn Header="Duration" Width="80"  DisplayMemberBinding="{Binding DurationDisplay}"/>
              <GridViewColumn Header="Format"   Width="160" DisplayMemberBinding="{Binding FormatDisplay}"/>
            </GridView.Columns>
          </GridView>
        </ListView.View>
      </ListView>

      <Border Grid.Row="1" Margin="0,10,0,0" Padding="10,8"
              BorderBrush="#888" BorderThickness="1" CornerRadius="4">
        <StackPanel Orientation="Horizontal">
          <CheckBox x:Name="GaplessCheck" Content="Gapless (DAO)"
                    VerticalAlignment="Center"
                    ToolTip="Disc-At-Once cue-sheet burn — no 2-second gaps between tracks."/>
          <CheckBox x:Name="CdTextCheck" Content="CD-Text"
                    VerticalAlignment="Center" Margin="18,0,0,0"
                    Checked="CdTextCheck_Changed" Unchecked="CdTextCheck_Changed"
                    ToolTip="Write artist/album/titles into the disc so players show track names. Implies gapless."/>
          <TextBlock Text="Album:" VerticalAlignment="Center" Margin="18,0,4,0"/>
          <TextBox x:Name="AlbumBox" Width="160" VerticalAlignment="Center" IsEnabled="False"/>
          <TextBlock Text="Artist:" VerticalAlignment="Center" Margin="12,0,4,0"/>
          <TextBox x:Name="ArtistBox" Width="160" VerticalAlignment="Center" IsEnabled="False"/>
        </StackPanel>
      </Border>

      <Grid Grid.Row="2" Margin="0,10,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="TotalText"
                     FontSize="13"/>
          <TextBlock x:Name="FitsText"
                     FontSize="11"
                     Opacity="0.65"
                     Margin="0,2,0,0"/>
        </StackPanel>
        <Button x:Name="BurnBtn"
                Grid.Column="1"
                Content="Burn"
                Click="Burn_Click"
                Padding="30,6"
                FontSize="14"/>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
