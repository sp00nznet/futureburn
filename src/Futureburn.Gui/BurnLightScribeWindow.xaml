<Window x:Class="Futureburn.Gui.BurnLightScribeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Burn Label (LightScribe)"
        Height="540" Width="720"
        MinHeight="420" MinWidth="600"
        WindowStartupLocation="CenterOwner">
  <DockPanel>

    <ToolBar DockPanel.Dock="Top">
      <Button Content="Choose image..." Click="ChooseImage_Click" Padding="10,4"/>
      <Separator/>
      <TextBlock Text="Drive:" VerticalAlignment="Center" Margin="6,0,4,0"/>
      <ComboBox x:Name="DriveCombo" Width="240"/>
      <Separator/>
      <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="6,0,4,0"/>
      <ComboBox x:Name="QualityCombo" Width="80" SelectedIndex="2">
        <ComboBoxItem Content="draft"/>
        <ComboBoxItem Content="normal"/>
        <ComboBoxItem Content="best"/>
      </ComboBox>
      <TextBlock Text="Copies:" VerticalAlignment="Center" Margin="12,0,4,0"/>
      <TextBox x:Name="CopiesBox" Text="1" Width="40" VerticalContentAlignment="Center"/>
    </ToolBar>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusText" Text="Pick a label image to burn."/>
      </StatusBarItem>
      <Separator/>
      <StatusBarItem>
        <ProgressBar x:Name="Progress" Width="240" Height="14" Minimum="0" Maximum="100"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap">
        <Run Text="Burn a grayscale image to the top of a LightScribe disc. "/>
        <Run FontStyle="Italic" Text="Disc must be a LightScribe-coated disc (logo on top), inserted UPSIDE DOWN — label coating toward the laser. "/>
        <Run Text="Quality 'best' takes ~25 min for CD-R, ~30 min for DVD-R. 'draft' is ~3 min."/>
      </TextBlock>

      <Border Grid.Row="1"
              BorderBrush="#888"
              BorderThickness="1"
              CornerRadius="4"
              Padding="14"
              Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Selected image:" FontWeight="SemiBold"/>
          <TextBlock x:Name="ImagePathText" Margin="0,4,0,0" Text="(none)" Opacity="0.8" TextTrimming="CharacterEllipsis"/>
          <TextBlock x:Name="ImageDimsText" Margin="0,2,0,0" Opacity="0.6"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="#bbb"
              BorderThickness="1"
              Background="White"
              Margin="0,0,0,10">
        <Image x:Name="PreviewImage"
               Stretch="Uniform"
               StretchDirection="DownOnly"
               Margin="6"/>
      </Border>

      <Grid Grid.Row="3" Margin="0,4,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="DriveStatusText" VerticalAlignment="Center"/>
        <Button x:Name="BurnBtn"
                Grid.Column="1"
                Content="Burn label"
                Click="Burn_Click"
                Padding="30,6"
                FontSize="14"
                IsEnabled="False"/>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
