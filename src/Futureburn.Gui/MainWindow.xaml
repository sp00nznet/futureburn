<Window x:Class="Futureburn.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="futureburn"
        Height="500" Width="720"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <Style x:Key="TileButton" TargetType="Button">
      <Setter Property="Margin" Value="10"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <DockPanel>

    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="E_xit" Click="Exit_Click"/>
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About futureburn" Click="About_Click"/>
      </MenuItem>
    </Menu>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusText" Text="ready"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource TileButton}" Click="BurnAudio_Click">
        <StackPanel>
          <TextBlock Text="Burn Audio CD" FontSize="22" HorizontalAlignment="Center"/>
          <TextBlock Text="MP3s in. Disc out. Magic."
                     FontSize="11" Opacity="0.6" Margin="0,8,0,0"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource TileButton}" Click="BurnVideo_Click">
        <StackPanel>
          <TextBlock Text="Burn Blu-ray / DVD" FontSize="22" HorizontalAlignment="Center"/>
          <TextBlock Text="Drop your movie. Burn. Plays itself when the disc loads."
                     FontSize="11" Opacity="0.6" Margin="0,8,0,0"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource TileButton}" Click="CdInfo_Click">
        <StackPanel>
          <TextBlock Text="CD Info" FontSize="22" HorizontalAlignment="Center"/>
          <TextBlock Text="What is this disc and why is it here?"
                     FontSize="11" Opacity="0.6" Margin="0,8,0,0"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource TileButton}" Click="BurnLabel_Click">
        <StackPanel>
          <TextBlock Text="Burn Label (LightScribe)" FontSize="22" HorizontalAlignment="Center"/>
          <TextBlock Text="Etch a picture onto the top of the disc. Yes, really."
                     FontSize="11" Opacity="0.6" Margin="0,8,0,0"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>

    </Grid>
  </DockPanel>
</Window>
