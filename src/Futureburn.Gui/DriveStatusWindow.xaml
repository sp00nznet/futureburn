<Window x:Class="Futureburn.Gui.DriveStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drives"
        Height="460" Width="660"
        MinHeight="300" MinWidth="480"
        WindowStartupLocation="CenterOwner">
  <DockPanel>

    <ToolBar DockPanel.Dock="Top">
      <Button Content="Refresh" Click="Refresh_Click" Padding="14,4"/>
      <TextBlock Text="  what's in each optical drive right now"
                 VerticalAlignment="Center" Opacity="0.6"/>
    </ToolBar>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <TextBlock x:Name="StatusText" Text="reading drives ..."/>
      </StatusBarItem>
    </StatusBar>

    <TextBox x:Name="ReadoutText"
             Margin="10"
             IsReadOnly="True"
             FontFamily="Consolas"
             FontSize="13"
             Background="#1E1E1E"
             Foreground="#DDDDDD"
             BorderThickness="0"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>

  </DockPanel>
</Window>
